{%- liquid
  assign arrows_class = 'blaze-navigation-arrows'
  assign prev_button_class = 'blaze-button-prev'
  assign next_button_class = 'blaze-button-next'
  assign navigation_style = navigation_style | default: 'default'
-%}

<div
  class="{{ arrows_class }} flex-between g-1 {% if navigation_style == 'inline' %}inline w-100{% else %}max-w-max{% endif %}{% if hide_on_mobile == true %} to-sm-hidden{% endif %}"
  {{ shopify_attributes }}
>
  <button type="button" class="{{ prev_button_class }}" aria-label="Previous slide">
    {{ 'icon--slider-prev.svg' | inline_asset_content }}
  </button>
  <button type="button" class="{{ next_button_class }}" aria-label="Next slide">
    {{ 'icon--slider-next.svg' | inline_asset_content }}
  </button>
</div>

{%- stylesheet -%}

  .blaze-navigation-arrows:has(.blaze-button-prev[disabled] + .blaze-button-next[disabled]) {
    display: none;
  }

  .blaze-navigation-arrows .blaze-button-prev,
  .blaze-navigation-arrows .blaze-button-next {
    position: static;
    width: 31px;
    height: 31px;
    margin-top: 0;
    padding: 0;
    user-select: none;
  }

  .blaze-navigation-arrows .blaze-button-prev:hover,
  .blaze-navigation-arrows .blaze-button-next:hover {
    opacity: 0.5;
  }

  .blaze-navigation-arrows .blaze-button-prev::after,
  .blaze-navigation-arrows .blaze-button-next::after {
    display: none;
  }

  .blaze-navigation-arrows .blaze-button-prev img,
  .blaze-navigation-arrows .blaze-button-next img {
    border-radius: 50%;
    cursor: pointer;
  }

  .blaze-navigation-arrows .blaze-button-prev[disabled],
  .blaze-navigation-arrows .blaze-button-next[disabled] {
    cursor: not-allowed;
    opacity: 0.2;
  }

  .slider-section:has(.content-container .inline) .section-header .blaze-navigation-arrows {
    display: none;
  }

  .content-container .inline {
    --slider-inline-page-width: var(--page-width);
  }

  .content-container .page-width--narrow.inline {
    --slider-inline-page-width: var(--page-width-narrow);
  }

  .content-container .page-width--wide.inline {
    --slider-inline-page-width: var(--page-width-wide);
  }

  .blaze-container-wrapper > .blaze-navigation-arrows.inline {
    pointer-events: none;
  }

  .blaze-container-wrapper > .blaze-navigation-arrows.inline .blaze-button-prev,
  .blaze-container-wrapper > .blaze-navigation-arrows.inline .blaze-button-next {
    pointer-events: auto;
    position: absolute;
    top: 50%;
    z-index: 1;
    width: 35px;
    height: 35px;
    margin: 0;
    margin-top: 0;
    padding: 0;
    user-select: none;
  }

  .blaze-container-wrapper > .blaze-navigation-arrows.inline .blaze-button-prev .slider-navigation-icon,
  .blaze-container-wrapper > .blaze-navigation-arrows.inline .blaze-button-next .slider-navigation-icon {
    display: none;
  }

  .blaze-container-wrapper > .blaze-navigation-arrows.inline .blaze-button-prev {
    left: max(
      clamp(
        var(--page-width-padding-mobile),
        calc(var(--padding-intercept) + var(--padding-slope) * 1vw),
        var(--page-width-padding)
      ),
      calc((100vw - var(--slider-inline-page-width)) / 2)
    );
    transform: translateY(50%) translateX(-50%);
  }

  .blaze-container-wrapper > .blaze-navigation-arrows.inline .blaze-button-next {
    right: max(
      clamp(
        var(--page-width-padding-mobile),
        calc(var(--padding-intercept) + var(--padding-slope) * 1vw),
        var(--page-width-padding)
      ),
      calc((100vw - var(--slider-inline-page-width)) / 2)
    );
    transform: translateY(50%) translateX(50%);
  }
{%- endstylesheet -%}
